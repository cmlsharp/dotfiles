#!/usr/bin/env bash
set -euo pipefail

# ── Paths ─────────────────────────────────────────────────────────
THEME_OUTPUT="$HOME/.config/theme"
DATA_DIR="$HOME/.local/share/theme"
THEMES_DIR="$DATA_DIR/themes"
TEMPLATES_DIR="$DATA_DIR/templates"
USER_THEMES_DIR="$HOME/.config/theme/themes"
USER_TEMPLATES_DIR="$HOME/.config/theme/templates"
CURRENT_PATH="$THEME_OUTPUT/current"

# ── Helpers ───────────────────────────────────────────────────────
usage() {
    echo "Usage: theme-set [--picker] [--bg-next] [theme-name]"
    echo ""
    echo "Options:"
    echo "  --picker    Interactive theme picker (rofi)"
    echo "  --bg-next   Cycle to next background for current theme"
    echo "  --list      List available themes"
    echo "  -h, --help  Show this help"
    exit 0
}

list_themes() {
    local -A seen
    for dir in "$THEMES_DIR" "$USER_THEMES_DIR"; do
        [[ -d "$dir" ]] || continue
        for f in "$dir"/*.toml; do
            [[ -f "$f" ]] || continue
            local name
            name=$(basename "$f" .toml)
            if [[ -z "${seen[$name]:-}" ]]; then
                echo "$name"
                seen["$name"]=1
            fi
        done
    done | sort
}

hex_to_rgb() {
    local hex="${1#\#}"
    printf "%d,%d,%d" "0x${hex:0:2}" "0x${hex:2:2}" "0x${hex:4:2}"
}

# ── Background cycling ────────────────────────────────────────────
cycle_background() {
    local theme_name
    theme_name=$(cat "$THEME_OUTPUT/current-name" 2>/dev/null || echo "")
    [[ -z "$theme_name" ]] && return 0

    local current_bg_link="$THEME_OUTPUT/current-background"
    local -a backgrounds=()

    # Collect backgrounds from user dir, then theme dir
    local user_bg_dir="$HOME/.config/theme/backgrounds/$theme_name"
    local theme_bg_dir="$CURRENT_PATH/backgrounds"

    for dir in "$user_bg_dir" "$theme_bg_dir"; do
        [[ -d "$dir" ]] || continue
        while IFS= read -r -d '' f; do
            backgrounds+=("$f")
        done < <(find -L "$dir" -maxdepth 1 -type f \( -name '*.jpg' -o -name '*.jpeg' -o -name '*.png' -o -name '*.webp' \) -print0 2>/dev/null | sort -z)
    done

    local total=${#backgrounds[@]}

    if (( total == 0 )); then
        return 0
    fi

    # Find current background index
    local current_bg=""
    if [[ -L "$current_bg_link" ]]; then
        current_bg=$(readlink "$current_bg_link")
    fi

    local index=-1
    for i in "${!backgrounds[@]}"; do
        if [[ "${backgrounds[$i]}" == "$current_bg" ]]; then
            index=$i
            break
        fi
    done

    # Cycle to the next background (wrap around)
    local next_index=$(( (index + 1) % total ))
    local new_bg="${backgrounds[$next_index]}"

    # Already showing this background — nothing to do
    [[ "$new_bg" == "$current_bg" ]] && return 0

    ln -nsf "$new_bg" "$current_bg_link"

    # Relaunch swaybg — start new instance before killing old to avoid flicker
    if command -v swaybg &>/dev/null; then
        local old_pids
        old_pids=$(pgrep -x swaybg || true)
        setsid uwsm-app -- swaybg -i "$current_bg_link" -m fill >/dev/null 2>&1 &
        disown
        sleep 0.3
        if [[ -n "$old_pids" ]]; then
            echo "$old_pids" | xargs kill 2>/dev/null || true
        fi
    fi
}

# ── Template processing ──────────────────────────────────────────
process_templates() {
    local colors_file="$STAGE_PATH/colors.toml"
    [[ -f "$colors_file" ]] || return 0

    local sed_script
    sed_script=$(mktemp)

    while IFS='=' read -r key value; do
        key="${key//[\"\' ]/}"
        [[ $key && $key != \#* ]] || continue
        value="${value#*[\"\']}"
        value="${value%%[\"\']*}"

        printf 's|{{ %s }}|%s|g\n' "$key" "$value"
        printf 's|{{ %s_strip }}|%s|g\n' "$key" "${value#\#}"
        if [[ $value =~ ^# ]]; then
            local rgb
            rgb=$(hex_to_rgb "$value")
            printf 's|{{ %s_rgb }}|%s|g\n' "$key" "$rgb"
        fi
    done < "$colors_file" > "$sed_script"

    shopt -s nullglob

    # Process user templates first, then built-in (user overrides built-in)
    for tpl in "$USER_TEMPLATES_DIR"/*.tpl "$TEMPLATES_DIR"/*.tpl; do
        local filename
        filename=$(basename "$tpl" .tpl)
        local output="$STAGE_PATH/$filename"

        # Don't overwrite files already in the theme (static overrides)
        if [[ ! -f "$output" ]]; then
            sed -f "$sed_script" "$tpl" > "$output"
        fi
    done

    rm -f "$sed_script"
}

# ── In-place config patching ─────────────────────────────────────
patch_starship() {
    local theme_name="$1"
    local starship_conf="$HOME/.config/starship.toml"
    [[ -f "$starship_conf" ]] || return 0

    local palette_name
    palette_name=$(echo "$theme_name" | tr '-' '_')
    local palette_file="$CURRENT_PATH/starship-palette.toml"
    [[ -f "$palette_file" ]] || return 0

    sed -i "s/^palette = .*/palette = \"${palette_name}\"/" "$starship_conf"

    local marker="# === THEME PALETTE (auto-generated) ==="
    if grep -q "$marker" "$starship_conf"; then
        sed -i "/$marker/,\$d" "$starship_conf"
    elif grep -q '^\[palettes\.' "$starship_conf"; then
        sed -i '/^\[palettes\./,$d' "$starship_conf"
    fi

    {
        echo "$marker"
        echo "[palettes.${palette_name}]"
        cat "$palette_file"
    } >> "$starship_conf"
}

patch_btop() {
    local btop_conf="$HOME/.config/btop/btop.conf"
    [[ -f "$btop_conf" ]] || return 0
    [[ -f "$CURRENT_PATH/btop.theme" ]] || return 0

    sed -i "s|^color_theme = .*|color_theme = \"$CURRENT_PATH/btop.theme\"|" "$btop_conf"
}

# ── GNOME/GTK integration ────────────────────────────────────────
set_gnome_theme() {
    command -v gsettings &>/dev/null || return 0

    if [[ -f "$CURRENT_PATH/light.mode" ]]; then
        gsettings set org.gnome.desktop.interface color-scheme "prefer-light" 2>/dev/null || true
    else
        gsettings set org.gnome.desktop.interface color-scheme "prefer-dark" 2>/dev/null || true
    fi

    if [[ -f "$CURRENT_PATH/gtk.theme" ]]; then
        local gtk_theme_name
        gtk_theme_name=$(basename "$(<"$CURRENT_PATH/gtk.theme")")
        gsettings set org.gnome.desktop.interface gtk-theme "$gtk_theme_name" 2>/dev/null || true
    elif [[ -f "$CURRENT_PATH/light.mode" ]]; then
        gsettings set org.gnome.desktop.interface gtk-theme "Adwaita" 2>/dev/null || true
    else
        gsettings set org.gnome.desktop.interface gtk-theme "Adwaita-dark" 2>/dev/null || true
    fi

    if [[ -f "$CURRENT_PATH/icons.theme" ]]; then
        gsettings set org.gnome.desktop.interface icon-theme "$(<"$CURRENT_PATH/icons.theme")" 2>/dev/null || true
    fi

    # GTK4 CSS override — symlink gtk.css/gtk-dark.css/assets from a full GTK theme
    local gtk4_dir="$HOME/.config/gtk-4.0"
    mkdir -p "$gtk4_dir"

    if [[ -f "$CURRENT_PATH/gtk.theme" ]]; then
        local gtk_theme_dir
        gtk_theme_dir="$(<"$CURRENT_PATH/gtk.theme")"
        local gtk4_src="$gtk_theme_dir/gtk-4.0"

        if [[ -d "$gtk4_src" ]]; then
            ln -sfn "$gtk4_src/gtk.css" "$gtk4_dir/gtk.css"
            ln -sfn "$gtk4_src/gtk-dark.css" "$gtk4_dir/gtk-dark.css" 2>/dev/null || true
            ln -sfn "$gtk4_src/assets" "$gtk4_dir/assets" 2>/dev/null || true
        fi
    else
        # No GTK override — remove custom CSS so stock Adwaita applies
        rm -f "$gtk4_dir/gtk.css" "$gtk4_dir/gtk-dark.css"
        rm -rf "$gtk4_dir/assets"
    fi
}

# ── Browser integration ──────────────────────────────────────────
set_browser_theme() {
    local chromium_theme="$CURRENT_PATH/chromium.theme"

    local theme_hex
    if [[ -f "$chromium_theme" ]]; then
        local rgb_color
        rgb_color=$(<"$chromium_theme")
        theme_hex=$(printf '#%02x%02x%02x' ${rgb_color//,/ })
    else
        # Derive from background color
        local colors_file="$CURRENT_PATH/colors.toml"
        if [[ -f "$colors_file" ]]; then
            theme_hex=$(awk -F'"' '/^background[[:space:]]*=/ {print $2; exit}' "$colors_file")
        fi
    fi

    [[ -z "${theme_hex:-}" ]] && return 0

    local policy="{\"BrowserThemeColor\": \"$theme_hex\"}"

    for browser_dir in /etc/chromium/policies/managed /etc/brave/policies/managed; do
        local browser_name
        browser_name=$(basename "$(dirname "$(dirname "$browser_dir")")")
        if command -v "$browser_name" &>/dev/null && [[ -d "$browser_dir" ]]; then
            echo "$policy" | sudo tee "$browser_dir/color.json" >/dev/null 2>&1 || true
        fi
    done

    # Refresh browser policies
    if command -v chromium &>/dev/null && pgrep -x chromium &>/dev/null; then
        chromium --refresh-platform-policy --no-startup-window &>/dev/null &
    fi
    if command -v brave &>/dev/null && pgrep -x brave &>/dev/null; then
        brave --refresh-platform-policy --no-startup-window &>/dev/null &
    fi

    # Firefox/Zen — write userChrome.css into all profiles
    local colors_file="$CURRENT_PATH/colors.toml"
    local toolbar_bg="$theme_hex"
    local toolbar_fg=""
    local sidebar_bg=""
    if [[ -f "$colors_file" ]]; then
        toolbar_fg=$(awk -F'"' '/^text[[:space:]]*=/ {print $2; exit}' "$colors_file")
        sidebar_bg=$(awk -F'"' '/^mantle[[:space:]]*=/ {print $2; exit}' "$colors_file")
    fi
    : "${toolbar_fg:=#cccccc}"
    : "${sidebar_bg:=$toolbar_bg}"

    local surface0=""
    if [[ -f "$colors_file" ]]; then
        surface0=$(awk -F'"' '/^surface0[[:space:]]*=/ {print $2; exit}' "$colors_file")
    fi
    : "${surface0:=$sidebar_bg}"

    local accent=""
    if [[ -f "$colors_file" ]]; then
        accent=$(awk -F'"' '/^accent[[:space:]]*=/ {print $2; exit}' "$colors_file")
    fi
    : "${accent:=$toolbar_fg}"

    local chrome_css
    chrome_css=$(cat <<CSSEOF
/* Auto-generated by theme-set — do not edit manually */
:root {
  --toolbar-bgcolor: ${toolbar_bg} !important;
  --toolbar-field-background-color: ${sidebar_bg} !important;
  --toolbar-field-color: ${toolbar_fg} !important;
  --toolbar-color: ${toolbar_fg} !important;
  --tab-selected-bgcolor: ${toolbar_bg} !important;
  --lwt-accent-color: ${toolbar_bg} !important;
  --lwt-toolbar-body-color: ${toolbar_fg} !important;

  /* Zen Browser overrides */
  --zen-primary-color: ${accent} !important;
}
CSSEOF
)

    for profile_root in "$HOME/.mozilla/firefox" "$HOME/.zen" "$HOME/.config/zen"; do
        [[ -d "$profile_root" ]] || continue
        for profile_dir in "$profile_root"/*/; do
            [[ -f "$profile_dir/prefs.js" ]] || continue
            mkdir -p "$profile_dir/chrome"
            echo "$chrome_css" > "$profile_dir/chrome/userChrome.css"
        done
    done

    # Restart Firefox/Zen to apply userChrome changes
    if pgrep -x firefox &>/dev/null; then
        killall firefox && setsid uwsm-app -- firefox &>/dev/null &
        disown
    fi
    if pgrep -x zen-browser &>/dev/null; then
        killall zen-browser && setsid uwsm-app -- zen-browser &>/dev/null &
        disown
    fi
}

# ── Reload apps ──────────────────────────────────────────────────
reload_apps() {
    # Walker — copy generated styles into walker theme dirs
    local walker_theme="$HOME/.config/walker/themes/omarchy"
    if [[ -d "$walker_theme" && -f "$CURRENT_PATH/walker-style.css" ]]; then
        cp -f "$CURRENT_PATH/walker-style.css" "$walker_theme/style.css"
    fi
    local walker_bw_theme="$HOME/.config/walker/themes/bitwarden"
    if [[ -d "$walker_bw_theme" && -f "$CURRENT_PATH/walker-bitwarden.css" ]]; then
        cp -f "$CURRENT_PATH/walker-bitwarden.css" "$walker_bw_theme/style.css"
    fi

    # Hyprland — no reload needed, inotify picks up file changes automatically

    # Waybar
    if pgrep -x waybar &>/dev/null; then
        killall waybar 2>/dev/null || true
        setsid uwsm-app -- waybar >/dev/null 2>&1 &
        disown
    fi

    # SwayNC
    if command -v swaync-client &>/dev/null && pgrep -x swaync &>/dev/null; then
        swaync-client --reload-css &>/dev/null || true
    fi

    # SwayOSD
    if pgrep -x swayosd-server &>/dev/null; then
        pkill -x swayosd-server 2>/dev/null || true
        setsid uwsm-app -- swayosd-server >/dev/null 2>&1 &
        disown
    fi

    # Kitty
    if pgrep -x kitty &>/dev/null; then
        killall -SIGUSR1 kitty 2>/dev/null || true
    fi

    # Tmux
    if command -v tmux &>/dev/null && tmux list-sessions &>/dev/null 2>&1; then
        tmux source-file ~/.tmux.conf 2>/dev/null || true
    fi

    # Btop
    if pgrep -x btop &>/dev/null; then
        pkill -SIGUSR2 btop 2>/dev/null || true
    fi
}

# ── Hooks ─────────────────────────────────────────────────────────
run_hooks() {
    local hook_dir="$HOME/.config/theme/hooks"
    if [[ -x "$hook_dir/post-set" ]]; then
        "$hook_dir/post-set" "$1" &>/dev/null || true
    fi
}

# ── Main ──────────────────────────────────────────────────────────
theme_name=""

case "${1:-}" in
    -h|--help) usage ;;
    --list) list_themes; exit 0 ;;
    --bg-next) cycle_background; exit 0 ;;
    --picker)
        if command -v walker &>/dev/null; then
            theme_name=$(list_themes | walker --dmenu -p "Theme")
        elif command -v rofi &>/dev/null; then
            theme_name=$(list_themes | rofi -dmenu -p "Theme" -i)
        else
            echo "Error: walker or rofi required for --picker mode" >&2
            exit 1
        fi
        [[ -z "$theme_name" ]] && exit 0
        ;;
    "") echo "Error: theme name required. Use --picker or provide a name." >&2; exit 1 ;;
    *) theme_name="$1" ;;
esac

theme_name=$(echo "$theme_name" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

# Find theme TOML
theme_file=""
for dir in "$USER_THEMES_DIR" "$THEMES_DIR"; do
    if [[ -f "$dir/${theme_name}.toml" ]]; then
        theme_file="$dir/${theme_name}.toml"
        break
    fi
done

if [[ -z "$theme_file" ]]; then
    echo "Error: theme '$theme_name' not found" >&2
    list_themes >&2
    exit 1
fi

# ── Generate and swap ─────────────────────────────────────────────
mkdir -p "$THEME_OUTPUT"

# Stage into a temp directory
STAGE_PATH=$(mktemp -d "$THEME_OUTPUT/.staging-XXXXXX")

# Copy theme TOML as colors.toml
cp "$theme_file" "$STAGE_PATH/colors.toml"

# Copy per-theme static overrides (from theme dir next to the TOML)
theme_override_dir="$(dirname "$theme_file")/${theme_name}"
if [[ -d "$theme_override_dir" ]]; then
    cp -r "$theme_override_dir/"* "$STAGE_PATH/" 2>/dev/null || true
fi

# Also check user overrides on top
user_override_dir="$USER_THEMES_DIR/${theme_name}"
if [[ -d "$user_override_dir" ]]; then
    cp -r "$user_override_dir/"* "$STAGE_PATH/" 2>/dev/null || true
fi

# Generate dynamic configs from templates (won't overwrite static overrides)
process_templates

# Overwrite files in-place so inotify watchers (Hyprland) see smooth updates
# instead of a directory disappearing and reappearing
if [[ -L "$CURRENT_PATH" ]]; then
    # Migrate from symlink approach: replace with real directory
    rm -f "$CURRENT_PATH"
fi
mkdir -p "$CURRENT_PATH"
# Remove files not in the new theme (e.g. light.mode from a previous theme)
for f in "$CURRENT_PATH"/*; do
    [[ -f "$f" ]] || continue
    [[ -f "$STAGE_PATH/$(basename "$f")" ]] || rm -f "$f"
done
cp -rf "$STAGE_PATH"/. "$CURRENT_PATH/"
rm -rf "$STAGE_PATH"

# Store theme name
echo "$theme_name" > "$THEME_OUTPUT/current-name"

# ── Post-switch actions ──────────────────────────────────────────
cycle_background
patch_starship "$theme_name"
patch_btop
set_gnome_theme
set_browser_theme
reload_apps

# Notify
if command -v notify-send &>/dev/null; then
    notify-send -t 3000 "Theme" "Switched to $theme_name"
fi

# Run user hooks
run_hooks "$theme_name"

echo "Theme switched to: $theme_name"
