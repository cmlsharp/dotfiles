set default-bg "{{ crust }}"
set default-fg "{{ foreground }}"

set statusbar-fg "{{ foreground }}"
set statusbar-bg "{{ background }}"
set inputbar-fg "{{ foreground }}"
set inputbar-bg "{{ background }}"

set notification-bg "{{ background }}"
set notification-fg "{{ green }}"
set notification-error-bg "{{ background }}"
set notification-error-fg "{{ red }}"
set notification-warning-bg "{{ background }}"
set notification-warning-fg "{{ yellow }}"

set completion-bg "{{ surface0 }}"
set completion-fg "{{ foreground }}"
set completion-highlight-bg "{{ accent }}"
set completion-highlight-fg "{{ background }}"
set completion-group-bg "{{ mantle }}"
set completion-group-fg "{{ foreground }}"

set highlight-color rgba({{ yellow_rgb }},0.5)
set highlight-active-color rgba({{ accent_rgb }},0.5)
set highlight-fg "{{ background }}"

set index-fg "{{ foreground }}"
set index-bg "{{ background }}"
set index-active-fg "{{ foreground }}"
set index-active-bg "{{ surface0 }}"

set recolor-lightcolor "{{ background }}"
set recolor-darkcolor "{{ foreground }}"
