up() {
    local n=${1:-1}
    local dir=""
    for ((i=0;i<n;i++)); do
        dir+="../"
    done
    cd "$dir" || return
}

open() {
    if (( $# == 0 )); then
        echo "At least one argument required"
        return 1
    fi

    local arg
    for arg in "$@"; do
        if [[ -e "$arg" ]]; then
            xdg-open "$arg" >/dev/null 2>&1 &
        else
            echo "Argument '$arg' does not exist"
        fi
    done
}

extract() {
    if (( $# == 0 )); then
        echo "Usage: extract [file ...]"
        return 1
    fi

    local file
    for file in "$@"; do
        if [[ ! -f "$file" ]]; then
            echo "extract: '$file' is not a valid file"
            continue
        fi

        case "$file" in
            *.tar.gz|*.tgz)       tar xvzf "$file" ;;
            *.tar.bz2|*.tbz|*.tbz2) tar xvjf "$file" ;;
            *.tar.xz|*.txz)       tar --xz -xvf "$file" ;;
            *.tar.zst)            tar -I zstd -xvf "$file" ;;
            *.tar)                tar xvf "$file" ;;
            *.gz)                 gunzip "$file" ;;
            *.bz2)                bunzip2 "$file" ;;
            *.xz)                 unxz "$file" ;;
            *.zip|*.war|*.jar)    unzip "$file" ;;
            *.rar)                unrar x -ad "$file" ;;
            *.7z)                 7za x "$file" ;;
            *)                    echo "extract: '$file' cannot be extracted" ;;
        esac
    done
}

alias x='extract'
