#!/bin/bash

# Modular hierarchical menu system driven by JSONC config.
# Uses walker --dmenu for display, jq for parsing.

MENU_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/menu/menu.json"
ALLOW_REPEAT=true

MENU_JSON=""
load_config() {
    if [[ ! -f "$MENU_CONFIG" ]]; then
        notify-send -u critical "Menu" "Config not found: $MENU_CONFIG"
        exit 1
    fi
    MENU_JSON=$(cat "$MENU_CONFIG")
}

# Navigate to a node by dot-separated path (e.g. "toggle" or "system")
# Searches by label match (case-insensitive, ignores icons)
resolve_path() {
    local node="$1"
    local path="$2"

    if [[ -z "$path" ]]; then
        echo "$node"
        return
    fi

    local segment="${path%%.*}"
    local rest="${path#*.}"
    [[ "$rest" == "$segment" ]] && rest=""

    local child
    child=$(echo "$node" | jq -r --arg s "$segment" '
        .items // [] | map(select(
            (.label | gsub("^[^a-zA-Z]+"; "") | ltrimstr(" ") | ascii_downcase) as $clean |
            ($s | ascii_downcase) as $search |
            $clean | startswith($search)
        )) | first // empty
    ')

    if [[ -z "$child" || "$child" == "null" ]]; then
        echo "$node"
        return
    fi

    resolve_path "$child" "$rest"
}

show_menu() {
    local node="$1"
    local parent_node="$2"

    local prompt width
    prompt=$(echo "$node" | jq -r '.prompt // "Menu"')
    width=$(echo "$node" | jq -r '.width // 295')

    # Dynamic items: if items is a string, run it as a command to get JSON array
    local items_type
    items_type=$(echo "$node" | jq -r '.items | type // "null"')
    if [[ "$items_type" == "string" ]]; then
        local items_cmd
        items_cmd=$(echo "$node" | jq -r '.items')
        local dynamic_items
        dynamic_items=$(eval "$items_cmd" 2>/dev/null)
        [[ -z "$dynamic_items" ]] && return
        node=$(echo "$node" | jq --argjson items "$dynamic_items" '.items = $items')
    fi

    local labels
    labels=$(echo "$node" | jq -r '.items[]?.label')

    if [[ -z "$labels" ]]; then
        return
    fi

    # Preselect current value if a "current" command is defined
    local walker_args=()
    local current_cmd
    current_cmd=$(echo "$node" | jq -r '.current // empty')
    if [[ -n "$current_cmd" ]]; then
        local current_val
        current_val=$(eval "$current_cmd" 2>/dev/null)
        if [[ -n "$current_val" ]]; then
            local idx
            idx=$(echo "$labels" | grep -nxF "$current_val" | head -1 | cut -d: -f1)
            [[ -n "$idx" ]] && walker_args+=(-c "$idx")
        fi
    fi

    local selection
    selection=$(echo "$labels" | walker --dmenu --minwidth "$width" -p "$prompt" "${walker_args[@]}" 2>/dev/null)

    if [[ -z "$selection" ]]; then
        [[ -n "$parent_node" ]] && show_menu "$parent_node"
        return
    fi

    local selected
    selected=$(echo "$node" | jq --arg sel "$selection" '.items[] | select(.label == $sel)')

    if [[ -z "$selected" ]]; then
        show_menu "$node" "$parent_node"
    fi

    local has_items
    has_items=$(echo "$selected" | jq 'has("items")')

    if [[ "$has_items" == "true" ]]; then
        # Inherit parent width/prompt if not set
        local child
        child=$(echo "$selected" | jq --argjson w "$width" '
            if .width == null then .width = $w else . end
        ')
        show_menu "$child" "$node"
    else
        local cmd terminal_mode repeat
        cmd=$(echo "$selected" | jq -r '.exec // empty')
        terminal_mode=$(echo "$selected" | jq -r '.terminal // false')
        repeat=$([[ "$ALLOW_REPEAT" == "true" ]] && echo "$node" | jq -r '.repeat // false' || echo false)

        if [[ -n "$cmd" ]]; then
            if [[ "$terminal_mode" == "true" ]]; then
                kitty --class floating-tui --title "$cmd" bash -c "$cmd; echo; echo -n 'Press enter to close...'; read"
            elif [[ "$repeat" == "true" ]]; then
                eval "$cmd"
            else
                eval exec $cmd
            fi
        fi

        if [[ "$repeat" == "true" ]]; then
            show_menu "$node" "$parent_node"
        fi
    fi
}

# Toggle: close existing menu if open
if pgrep -f "walker.*--dmenu" >/dev/null 2>&1; then
    # Kill other menu instances so back-navigation doesn't reopen walker
    pgrep -f "bash.*/.config/menu/menu" | grep -v "^$$\$" | xargs -r kill 2>/dev/null
    walker --close >/dev/null 2>&1
    exit 0
fi

load_config

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --no-repeat) ALLOW_REPEAT=false; shift ;;
        --go) GO_PATH="$2"; shift 2 ;;
        *) shift ;;
    esac
done

if [[ -n "${GO_PATH:-}" ]]; then
    node=$(resolve_path "$(echo "$MENU_JSON")" "$GO_PATH")
    show_menu "$node"
else
    show_menu "$MENU_JSON"
fi
