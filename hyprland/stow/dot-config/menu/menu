#!/usr/bin/env python3
import os
import re
import subprocess
import sys
from pathlib import Path
from typing import Any

import yaml

CONFIG_PATH = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "menu" / "menu.yml"


def load_config(path: Path) -> Any:
    if not path.exists():
        subprocess.run(
            ["notify-send", "-u", "critical", "Menu", f"Config not found: {path}"],
            check=False,
        )
        sys.exit(1)
    return yaml.safe_load(path.read_text())


def _label_key(label: str) -> str:
    return re.sub(r"^[^a-zA-Z]+", "", label).lstrip().lower()


def resolve_path(node: Any, path: str) -> Any:
    if not path:
        return node

    segment, _, rest = path.partition(".")
    segment_lower = segment.lower()

    for item in (node.get("items") or []):
        if isinstance(item, dict) and _label_key(item.get("label", "")).startswith(segment_lower):
            return resolve_path(item, rest)

    return node


def walker_dmenu(labels: list[str], prompt: str, width: int, preselect: int | None = None) -> str | None:
    cmd = ["walker", "--dmenu", "--minwidth", str(width), "-p", prompt]
    if preselect is not None:
        cmd += ["-c", str(preselect)]

    result = subprocess.run(cmd, input="\n".join(labels), text=True, capture_output=True)
    selected = result.stdout.strip()
    return selected if selected else None


def resolve_items(node: dict) -> list[dict] | None:
    items = node.get("items")
    if items is None:
        return None
    if isinstance(items, str):
        result = subprocess.run(items, shell=True, text=True, capture_output=True)
        if result.returncode != 0 or not result.stdout.strip():
            return None
        return yaml.safe_load(result.stdout)
    return items


def _terminal_class(large: bool) -> str:
    return "floating-tui-large" if large else "floating-tui"


def run_command(cmd: str, terminal: bool | dict, repeat: bool) -> None:
    if terminal:
        large = isinstance(terminal, dict) and terminal.get("large", False)
        cls = _terminal_class(large)
        subprocess.Popen([
            "kitty", "--class", cls, "--title", cmd,
            "bash", "-c", f'{cmd}; echo; echo -n "Press enter to close..."; read',
        ])
    elif repeat:
        subprocess.run(cmd, shell=True)
    else:
        os.execvp("bash", ["bash", "-c", f"exec {cmd}"])


def show_menu(node: Any, parent_node: Any = None, allow_repeat: bool = True) -> None:
    if not isinstance(node, dict):
        return

    prompt: str = node.get("prompt", "Menu")
    width: int = node.get("width", 295)

    items = resolve_items(node)
    if not items:
        return

    items_by_label = {item.get("label", ""): item for item in items if isinstance(item, dict)}
    labels = list(items_by_label.keys())
    if not labels:
        return

    preselect: int | None = None
    current_cmd: str | None = node.get("current")
    if current_cmd:
        result = subprocess.run(current_cmd, shell=True, text=True, capture_output=True)
        current_val = result.stdout.strip()
        if current_val and current_val in labels:
            preselect = labels.index(current_val) + 1  # walker -c is 1-based

    selection = walker_dmenu(labels, prompt, width, preselect)

    if selection is None:
        if parent_node is not None:
            show_menu(parent_node, allow_repeat=allow_repeat)
        return

    selected = items_by_label.get(selection)

    if selected is None:
        show_menu(node, parent_node, allow_repeat)
        return

    if "items" in selected:
        child = dict(selected)
        child.setdefault("width", width)
        show_menu(child, node, allow_repeat)
    else:
        cmd: str | None = selected.get("exec")
        terminal = selected.get("terminal", False)
        if not isinstance(terminal, (bool, dict)):
            terminal = False
        repeat = allow_repeat and bool(node.get("repeat", False))
        if cmd:
            run_command(cmd, terminal, repeat)
        if repeat:
            show_menu(node, parent_node, allow_repeat)


def kill_existing() -> bool:
    result = subprocess.run(["pgrep", "-f", "walker.*--dmenu"], capture_output=True, text=True)
    if not result.stdout.strip():
        return False

    my_pid = str(os.getpid())
    procs = subprocess.run(
        ["pgrep", "-f", r"python.*menu\.py"], capture_output=True, text=True,
    ).stdout.splitlines()
    for pid in procs:
        if pid.strip() and pid.strip() != my_pid:
            subprocess.run(["kill", pid.strip()], check=False)

    subprocess.run(["walker", "--close"], capture_output=True)
    return True


def parse_args(argv: list[str]) -> tuple[bool, str | None]:
    allow_repeat = True
    go_path: str | None = None
    i = 0
    while i < len(argv):
        if argv[i] == "--no-repeat":
            allow_repeat = False
        elif argv[i] == "--go" and i + 1 < len(argv):
            go_path = argv[i + 1]
            i += 1
        i += 1
    return allow_repeat, go_path


def main() -> None:
    if kill_existing():
        sys.exit(0)

    config = load_config(CONFIG_PATH)
    allow_repeat, go_path = parse_args(sys.argv[1:])

    if go_path:
        node = resolve_path(config, go_path)
        show_menu(node, allow_repeat=allow_repeat)
    else:
        show_menu(config, allow_repeat=allow_repeat)


if __name__ == "__main__":
    main()
