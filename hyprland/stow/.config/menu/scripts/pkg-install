#!/bin/bash

# Fuzzy package picker using paru + fzf
# Multi-select with tab, preview with alt-p, scroll with alt-j/k

pkg_names=$(paru -Slq | fzf \
    --multi \
    --preview 'paru -Sii {1} 2>/dev/null || paru -Si {1}' \
    --preview-label='alt-p: toggle preview, alt-j/k: scroll, tab: multi-select' \
    --preview-label-pos='bottom' \
    --preview-window 'down:65%:wrap' \
    --bind 'alt-p:toggle-preview' \
    --bind 'alt-d:preview-half-page-down,alt-u:preview-half-page-up' \
    --bind 'alt-k:preview-up,alt-j:preview-down' \
    --color 'pointer:green,marker:green')

if [[ -n "$pkg_names" ]]; then
    echo "$pkg_names" | tr '\n' ' ' | xargs paru -S --needed
fi
